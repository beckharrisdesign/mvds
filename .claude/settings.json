{
  "permissions": {
    "allow": [
      "Bash(gh pr view:*)",
      "Bash(gh pr list:*)",
      "Bash(gh pr checks:*)",
      "Bash(gh run view:*)",
      "Bash(gh run list:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git branch:*)",
      "Bash(git show:*)",
      "Bash(npm run build:*)",
      "Bash(npm run check:contrast:*)",
      "Bash(npm run check:principles:*)",
      "Bash(npm test:*)",
      "Bash(node scripts/check-contrast.mjs:*)",
      "Bash(node scripts/check-principles.mjs:*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node scripts/hooks/token-edit-guard.mjs",
            "statusMessage": "Checking token contrast…"
          },
          {
            "type": "command",
            "command": "node scripts/hooks/principle-edit-guard.mjs",
            "statusMessage": "Checking design principles…"
          }
        ]
      }
    ]
  }
}